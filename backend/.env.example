# ----- Server -----------------------------------------------------------
PORT=5000
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ----- Database -----------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=intern_portal
DB_USER=postgres
DB_PASSWORD=

# ----- Email (Gmail) --------------------------------------------------------
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ----- Slack integration (optional - features degrade if absent) -----------
# Create a Slack app at https://api.slack.com/apps, install it to your
# workspace, and copy the "Bot User OAuth Token" (starts with xoxb-).
# The bot must be invited into each channel below: /invite @YourBotName
SLACK_BOT_TOKEN=

# OAuth client credentials for the "Connect Slack" per-intern linking flow.
# Found in the Slack app under Basic Information -> App Credentials.
# The app must also have a Redirect URL (OAuth & Permissions) matching
# SLACK_REDIRECT_URI below, and a User Token Scope of: identify
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:5000/api/slack/oauth/callback

# These match the ACTUAL channels in this workspace - do not rename these
# defaults to generic placeholders, they will fail with channel_not_found.
SLACK_DEFAULT_CHANNEL=#all-intern-communication
SLACK_SUPERVISOR_CHANNEL=#supervisor
SLACK_ATTENDANCE_CHANNEL=#attendance

# Public base URL of the frontend, used in Slack "view in portal" links.
APP_URL=http://localhost:3000
